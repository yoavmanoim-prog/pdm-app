# ─────────────────────────────────────────────────────────────────────────────
# On-site configuration. Copy to ".env" (same folder as docker-compose.onsite.yml)
# and fill in real values:
#     cp .env.onsite.example .env
# The real .env is gitignored — never commit secrets.
# ─────────────────────────────────────────────────────────────────────────────

# Image version to run. Local/dev builds use "dev". A semantic version is only
# assigned when cutting a PRODUCTION release (release.sh stamps it into the
# shipped bundle's .env). Production bumping rules:
#   bug fix  → patch: x.y.(z+1)   e.g. 2.0.0 → 2.0.1
#   feature  → minor: x.(y+1).0   e.g. 2.0.1 → 2.1.0
VERSION=dev

# PostgreSQL password for the bundled database. Pick any strong value.
DB_PASSWORD=change-me-strong-db-password

# Secret used to sign login tokens AND file-download links.
# Generate a strong one:   openssl rand -hex 32
JWT_SECRET=change-me-run-openssl-rand-hex-32

# First-run administrator. Created automatically the first time the stack starts
# if no admin exists yet. Log in with these, then change the password in the UI.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-strong-admin-password

# Folder on THIS server that the "Browse / commit from a folder" picker reads
# (read-only) — e.g. a shared drawings directory. Defaults to ./watch next to
# this file if unset. Create it (or point it at your share) before first start.
WATCH_DIR=./watch
