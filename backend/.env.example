# Example local config — copy to backend/.env (gitignored) and fill in real values.
# Only variables WITHOUT a safe default in app/config.py need setting locally.

# First-admin bootstrap: seeds an admin account on a fresh DB if none exists yet.
# Leave blank to skip seeding (e.g. sign up, then promote the row to admin).
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me

# Secret used to sign login tokens. Defaults to an insecure dev value in
# app/config.py — override here for local, and via a real secret in staging/prod.
# JWT_SECRET=some-long-random-string
