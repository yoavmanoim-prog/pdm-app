[flake8]
max-line-length = 120
# F821 = undefined name — only the models use SQLAlchemy string forward references
# in Mapped["ClassName"] type hints, so the ignore is scoped to app/models/.
# Keeping F821 active everywhere else catches real bugs (e.g. names lost in a merge).
per-file-ignores =
    app/models/*.py:F821
